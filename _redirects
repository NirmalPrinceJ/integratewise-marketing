# Cloudflare Pages routing configuration
# Explicit routes are served first, then fallback rules

# Exclude API routes from SPA fallback
/api/* /api/:splat 200

# Exclude static assets and directories
/assets/* /assets/:splat 200
/images/* /images/:splat 200
/js/* /js/:splat 200

# Content pages - serve directly
/blog/* /blog/:splat 200
/resources/* /resources/:splat 200
/articles/* /articles/:splat 200
/use-cases/* /use-cases/:splat 200
/white-papers/* /white-papers/:splat 200

# Favicon and metadata
/favicon.ico /favicon.ico 200
/robots.txt /robots.txt 200
/sitemap.xml /sitemap.xml 200

# All other routes - SPA fallback to main index.html
/* /index.html 200
