{
  "name": "@integratewise/types",
  "version": "1.0.0",
  "description": "TypeScript type definitions for IntegrateWise",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./spine": {
      "types": "./dist/spine/index.d.ts",
      "import": "./dist/spine/index.js",
      "require": "./dist/spine/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NirmalPrinceJ/integratewise-os"
  },
  "license": "MIT"
}
