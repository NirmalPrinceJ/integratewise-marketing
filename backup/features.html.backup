          <div class="mock-node"><span class="dot"></span>Kiro</div>
        </div>
        <div style="text-align:center;margin:1rem 0">
          <span style="font-size:1.2rem;color:var(--gold)">↓ OAuth 2.0 ↓</span>
        </div>
        <div style="background:rgba(184,148,63,0.2);border:1px solid var(--gold);border-radius:4px;padding:0.75rem;text-align:center">
          <div style="font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:var(--paper)">CAPABILITY FABRIC</div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:0.5rem;color:rgba(244,240,232,0.7)">mcp.integratewise.ai</div>
        </div>
