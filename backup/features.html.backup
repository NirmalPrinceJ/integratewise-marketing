<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Features — IntegrateWise | Enterprise AI Capability Fabric</title>
  <meta name="description" content="The continuity layer that solves N×M integration explosion. Connect N tools + M AI models = N+M, not N×M. MCP-native architecture, persistent memory, enterprise governance.">
  <meta name="keywords" content="Enterprise AI Features, MCP Architecture, AI Capability Fabric, N×M Integration Problem, AI Memory, AI Governance">
  <link rel="canonical" href="https://integratewise.ai/features">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://integratewise.ai/features">
  <meta property="og:title" content="Features — IntegrateWise | Enterprise AI Capability Fabric">
  <meta property="og:description" content="The continuity layer: N tools + M AI models = N+M, not N×M. Connect once, authorize any AI, own the memory.">
  <meta property="og:image" content="https://integratewise.ai/og-image.png">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Serif+Display:ital@0;1&family=IBM+Plex+Mono:wght@400;500;600&family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
:root{--ink:#0C0C0C;--paper:#F4F0E8;--paper-warm:#EBE5D8;--rule:#C4BAA8;--forest:#1A3A2A;--forest-mid:#2D5A3D;--gold:#B8943F;--gold-pale:#F0E0B0;--slate:#1A2E4A;--red:#8B2020}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Instrument Sans',sans-serif;background:var(--paper);color:var(--ink);line-height:1.6;-webkit-font-smoothing:antialiased;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E")}
.display{font-family:'Bebas Neue',sans-serif;letter-spacing:0.02em}
.serif{font-family:'DM Serif Display',serif}
.mono{font-family:'IBM Plex Mono',monospace;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.15em}
a{color:inherit;text-decoration:none}
.btn{display:inline-flex;align-items:center;justify-content:center;padding:0.8rem 1.75rem;font-weight:600;font-size:0.875rem;border-radius:9999px;transition:all 0.2s;cursor:pointer;border:none}
.btn-gold{background:var(--gold);color:var(--forest)}.btn-gold:hover{background:var(--gold-pale)}
.btn-outline{border:2px solid rgba(244,240,232,0.4);color:var(--paper);background:transparent}.btn-outline:hover{border-color:var(--paper)}
.btn-forest{background:var(--forest);color:var(--paper)}.btn-forest:hover{background:var(--forest-mid)}
.label{display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.15em;padding:0.35rem 0.75rem;border-radius:0.375rem;border:1px solid var(--rule);color:var(--forest);margin-bottom:1rem}
.label-dark{border-color:rgba(184,148,63,0.4);color:var(--gold-pale)}
.wrap{max-width:80rem;margin:0 auto;padding:0 1.5rem}
@media(min-width:768px){.wrap{padding:0 2.5rem}}

/* UI MOCKS */
.mock-line{height:6px;background:rgba(244,240,232,0.2);border-radius:3px;margin-bottom:6px}
.mock-line.short{width:60%}
.mock-line.med{width:80%}
.mock-line.gold{background:var(--gold)}
.mock-dot{width:8px;height:8px;border-radius:50%;background:var(--gold);display:inline-block}
.mock-node{display:flex;align-items:center;gap:0.5rem;padding:0.4rem 0.6rem;background:rgba(244,240,232,0.1);border-radius:4px;font-family:'IBM Plex Mono',monospace;font-size:0.55rem;color:var(--paper);margin-bottom:4px}
.mock-node .dot{width:6px;height:6px;border-radius:50%;background:var(--gold)}
.mock-badge{display:inline-block;padding:0.2rem 0.5rem;background:var(--gold);color:var(--forest);font-family:'IBM Plex Mono',monospace;font-size:0.5rem;border-radius:3px;text-transform:uppercase}
.mock-flow{display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap}
.mock-arrow{color:var(--gold);font-size:0.75rem}
.mock-card{background:rgba(244,240,232,0.1);border-radius:4px;padding:0.5rem;margin-bottom:0.25rem}
.mock-card-title{font-family:'IBM Plex Mono',monospace;font-size:0.5rem;color:rgba(244,240,232,0.8);margin-bottom:0.25rem;text-transform:uppercase}
.mock-card-val{font-family:'Bebas Neue',sans-serif;font-size:1rem;color:var(--paper)}

/* FEATURE DEEP DIVE */
.feature-deep{padding:4rem 1.5rem;border-bottom:1px solid var(--rule)}
@media(min-width:768px){.feature-deep{padding:5rem 2.5rem}}
.feature-deep:last-of-type{border-bottom:none}
.feature-deep.alt{background:var(--paper-warm)}
.fd-grid{display:grid;grid-template-columns:1fr;gap:2.5rem;align-items:start}
@media(min-width:1024px){.fd-grid{grid-template-columns:1fr 1fr}}
.fd-content .fd-num{font-family:'IBM Plex Mono',monospace;font-size:0.65rem;color:var(--gold);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:0.5rem}
.fd-content h2{font-family:'Bebas Neue',sans-serif;font-size:clamp(1.5rem,3vw,2rem);color:var(--ink);margin-bottom:1rem;letter-spacing:0.01em}
.fd-content .lead{font-size:1rem;color:var(--slate);line-height:1.7;margin-bottom:1.5rem}
.fd-list{list-style:none}
.fd-list li{display:flex;align-items:flex-start;gap:0.6rem;font-size:0.875rem;color:var(--slate);line-height:1.5;margin-bottom:0.6rem}
.fd-list li::before{content:'→';color:var(--gold);font-weight:700;flex-shrink:0}
.fd-mock{background:var(--forest);border-radius:0.75rem;padding:1.5rem;min-height:280px}
.fd-mock-light{background:var(--paper);border:1px solid var(--rule)}

/* NAV */
.nav{position:sticky;top:0;z-index:50;background:rgba(244,240,232,0.95);backdrop-filter:blur(8px);border-bottom:1px solid var(--rule);padding:0.75rem 2rem;display:flex;align-items:center;justify-content:space-between}
.nav-logo{display:flex;align-items:center;gap:0.75rem}
.nav-logo img{height:32px;width:auto}
.nav-logo span{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:0.04em;color:var(--forest)}
.nav-links{display:none;gap:1.5rem;align-items:center}
.nav-links a{font-family:'IBM Plex Mono',monospace;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--slate)}
.nav-links a:hover{color:var(--forest)}
.nav-cta{padding:0.5rem 1.25rem;background:var(--forest);color:var(--paper);font-weight:600;font-size:0.75rem;border-radius:9999px}
@media(min-width:768px){.nav-links{display:flex}}

/* HERO */
.hero{min-height:50vh;display:flex;align-items:center;background:var(--forest);color:var(--paper);padding:4rem 1.5rem}
@media(min-width:768px){.hero{padding:5rem 2.5rem}}
.hero-inner{max-width:64rem;margin:0 auto;text-align:center}
.hero h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(2rem,6vw,4rem);line-height:1.05;letter-spacing:0.02em;margin-bottom:1.5rem}
.hero .sub{font-family:'DM Serif Display',serif;font-size:clamp(0.95rem,2vw,1.15rem);opacity:0.85;max-width:42rem;margin:0 auto 2rem;line-height:1.6;font-style:italic}

/* BENTO GRID */
.bento-section{padding:4rem 0}
.bento-grid{display:grid;grid-template-columns:1fr;gap:1rem}
@media(min-width:640px){.bento-grid{grid-template-columns:repeat(2,1fr)}}
@media(min-width:1024px){.bento-grid{grid-template-columns:repeat(4,1fr);grid-auto-rows:minmax(180px,auto)}}
.bento-card{background:var(--paper-warm);border:1px solid var(--rule);border-radius:1rem;padding:1.5rem;position:relative;overflow:hidden;display:flex;flex-direction:column}
.bento-card.span-2{grid-column:span 1}
@media(min-width:640px){.bento-card.span-2{grid-column:span 2}}
.bento-card.span-3{grid-column:span 1}
@media(min-width:1024px){.bento-card.span-3{grid-column:span 3}}
.bento-card.span-4{grid-column:span 1}
@media(min-width:1024px){.bento-card.span-4{grid-column:span 4}}
.bento-card.row-2{grid-row:span 2}
.bento-card.dark{background:var(--forest);color:var(--paper);border-color:var(--forest-mid)}
.bento-card.accent{background:linear-gradient(135deg,var(--gold) 0%,#D4A84A 100%);color:var(--forest);border-color:var(--gold)}
.bento-num{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:var(--gold);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.5rem}
.bento-card.dark .bento-num{color:var(--gold-pale)}
.bento-card.accent .bento-num{color:var(--forest);opacity:0.7}
.bento-title{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:0.01em;margin-bottom:0.75rem;line-height:1.15}
.bento-desc{font-size:0.85rem;line-height:1.6;opacity:0.85;flex:1}
.bento-card.dark .bento-desc{opacity:0.75}

/* STATS GRID */
.stats-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem}
@media(min-width:768px){.stats-grid{grid-template-columns:repeat(4,1fr)}}
.stat{text-align:center;padding:1.5rem 1rem;background:var(--paper);border:1px solid var(--rule);border-radius:0.5rem}
.stat-num{font-family:'Bebas Neue',sans-serif;font-size:clamp(2rem,5vw,3rem);color:var(--gold);line-height:1}
.stat-label{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:var(--slate);letter-spacing:0.1em;text-transform:uppercase;margin-top:0.5rem}

/* FOOTER */
.footer{border-top:1px solid var(--rule);padding:3rem 2rem 2rem;background:var(--paper-warm)}
.footer-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2rem;max-width:72rem;margin:0 auto}
@media(min-width:768px){.footer-grid{grid-template-columns:repeat(4,1fr)}}
.footer-col h4{font-family:'IBM Plex Mono',monospace;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--forest);margin-bottom:1rem}
.footer-col a{display:block;font-size:0.8rem;color:var(--slate);margin-bottom:0.5rem}
.footer-col a:hover{color:var(--forest)}
.footer-bottom{max-width:72rem;margin:2rem auto 0;padding-top:1.5rem;border-top:1px solid var(--rule);display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:1rem}
.footer-bottom p{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:var(--slate);opacity:0.6;letter-spacing:0.08em}
  </style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <a href="/" class="nav-logo">
    <img src="/images/logo-dark.svg" alt="IntegrateWise">
    <span>INTEGRATEWISE</span>
  </a>
  <div class="nav-links">
    <a href="/features">Features</a>
    <a href="/how-it-works">How It Works</a>
    <a href="/pricing">Pricing</a>
    <a href="/blog/">Blog</a>
    <a href="/contact" class="nav-cta">Book a Demo</a>
  </div>
</nav>

/* UI MOCK STYLES */
.ui-mock{background:var(--paper);border:1px solid var(--rule);border-radius:0.5rem;padding:0.75rem;margin-top:1rem;font-size:0.7rem}
.ui-mock-header{display:flex;gap:0.35rem;margin-bottom:0.5rem}
.ui-mock-dot{width:8px;height:8px;border-radius:50%;background:var(--rule)}
.ui-mock-dot.red{background:#E5534B}
.ui-mock-dot.yellow{background:#D4A84A}
.ui-mock-dot.green{background:#3D8B40}
.ui-mock-row{display:flex;gap:0.5rem;margin-bottom:0.35rem;align-items:center}
.ui-mock-block{height:8px;border-radius:2px;background:var(--rule)}
.ui-mock-block.w1{width:30%}
.ui-mock-block.w2{width:50%}
.ui-mock-block.w3{width:70%}
.ui-mock-block.gold{background:var(--gold)}
.ui-mock-block.forest{background:var(--forest)}
.ui-mock-icon{width:16px;height:16px;border-radius:4px;background:var(--forest);flex-shrink:0}
.ui-mock-icon.gold{background:var(--gold)}
.ui-mock-card{background:var(--paper-warm);border:1px solid var(--rule);border-radius:4px;padding:0.5rem;margin-top:0.5rem}
.ui-mock-badge{display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:0.55rem;padding:0.15rem 0.4rem;border-radius:3px;background:var(--forest);color:var(--paper);text-transform:uppercase;letter-spacing:0.08em}
.ui-mock-badge.pending{background:var(--gold);color:var(--forest)}
.ui-mock-badge.approved{background:#3D8B40;color:var(--paper)}

/* DIAGRAM STYLES */
.diagram{padding:1.5rem 0}
.diagram-flow{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:0.75rem}
.diagram-node{background:var(--paper);border:2px solid var(--rule);border-radius:0.5rem;padding:0.6rem 1rem;font-family:'IBM Plex Mono',monospace;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.08em;text-align:center}
.diagram-node.highlight{border-color:var(--gold);background:var(--gold-pale)}
.diagram-node.dark{background:var(--forest);border-color:var(--forest);color:var(--paper)}
.diagram-arrow{color:var(--gold);font-size:1.2rem;font-weight:bold}
.diagram-plus{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--forest)}
.diagram-equals{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--gold)}

/* FEATURE DETAIL SECTIONS */
.feature-section{padding:5rem 0;border-bottom:1px solid var(--rule)}
.feature-section:last-of-type{border-bottom:none}
.feature-section.alt{background:var(--paper-warm)}
.feature-grid{display:grid;grid-template-columns:1fr;gap:3rem;align-items:center}
@media(min-width:768px){.feature-grid{grid-template-columns:1fr 1fr}}
.feature-grid.reverse .feature-content{order:1}
@media(min-width:768px){.feature-grid.reverse .feature-content{order:2}.feature-grid.reverse .feature-visual{order:1}}
.feature-num{font-family:'IBM Plex Mono',monospace;font-size:0.65rem;color:var(--gold);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.5rem}
.feature-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(1.5rem,3vw,2rem);color:var(--ink);margin-bottom:1rem;letter-spacing:0.01em;line-height:1.15}
.feature-desc{font-size:0.95rem;color:var(--slate);line-height:1.7;margin-bottom:1.5rem}
.feature-list{list-style:none}
.feature-list li{display:flex;align-items:flex-start;gap:0.6rem;font-size:0.875rem;color:var(--slate);line-height:1.5;margin-bottom:0.6rem}
.feature-list li::before{content:'→';color:var(--gold);font-weight:700;flex-shrink:0}

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <span class="label label-dark">Platform Features</span>
    <h1>THE CONTINUITY LAYER<br>FOR ENTERPRISE AI</h1>
    <p class="sub">Six pillars of infrastructure that transform the N×M integration explosion into an N+M capability fabric. Connect once. Authorize any AI. Own the intelligence layer forever.</p>
  </div>
</section>

<!-- N+M TRANSFORMATION -->
<section class="section" style="background:var(--paper)">
  <div class="wrap-md">
    <div style="text-align:center;margin-bottom:2rem">
      <span class="label">Core Innovation</span>
      <h2 class="display" style="font-size:clamp(1.6rem,3.5vw,2.2rem);margin-top:0.5rem">THE N+M TRANSFORMATION</h2>
      <p style="font-size:0.95rem;color:var(--slate);margin-top:1rem;max-width:36rem;margin-left:auto;margin-right:auto">IntegrateWise turns multiplicative integration complexity into additive simplicity.</p>
    </div>
    
    <div class="nm-visual">
      <div class="nm-grid">
        <div class="nm-box nm-bad">
          <div class="nm-title" style="color:var(--red)">Without IntegrateWise</div>
          <div class="nm-formula" style="color:var(--red)">N × M</div>
          <div class="nm-result">10 AIs × 100 Systems = <strong style="color:var(--red)">1,000 integrations</strong></div>
        </div>
        <div class="nm-arrow">→</div>
        <div class="nm-box nm-good">
          <div class="nm-title" style="color:var(--gold)">With IntegrateWise</div>
          <div class="nm-formula" style="color:var(--gold)">N + M</div>
          <div class="nm-result">10 AIs + 100 Systems = <strong style="color:var(--forest)">110 connections</strong></div>
        </div>
      </div>
    </div>
    
    <p style="font-size:0.95rem;color:var(--slate);text-align:center;line-height:1.7">Each AI connects once to the Capability Fabric. Each system connects once to the Capability Fabric. The fabric handles the translation, normalization, and routing. Complexity stays <strong>additive</strong>, not multiplicative.</p>
  </div>
</section>

<!-- BENTO GRID OVERVIEW -->
<section class="section" style="background:var(--paper-warm)">
  <div class="wrap">
    <div style="text-align:center;margin-bottom:2.5rem">
      <span class="label">Platform Capabilities</span>
      <h2 class="display" style="font-size:clamp(1.6rem,3.5vw,2.2rem);margin-top:0.5rem">SIX PILLARS OF ENTERPRISE AI INFRASTRUCTURE</h2>
    </div>
    
    <div class="bento">
      <!-- 1. MCP-Native Architecture - Tall -->
      <div class="bento-item tall">
        <div class="bento-num">01 · Architecture</div>
        <div class="bento-title">MCP-Native Protocol</div>
        <div class="bento-desc">Built from first principles on Model Context Protocol. Every connection speaks MCP natively — no translation layers.</div>
        <div class="bento-mock">
          <div class="mock-node"><span class="dot"></span>POST /mcp</div>
          <div class="mock-node"><span class="dot"></span>OAuth 2.0 RS256</div>
          <div class="mock-node"><span class="dot"></span>18 Canonical Tools</div>
          <div style="margin-top:0.5rem">
            <span class="mock-badge">MCP 1.0</span>
          </div>
        </div>
      </div>
      
      <!-- 2. Capability Fabric - Span 2 -->
      <div class="bento-item span-2">
        <div class="bento-num">02 · Core Engine</div>
        <div class="bento-title">Capability Fabric (The Spine)</div>
        <div class="bento-desc">Canonical entity resolution. One Person exists once across all systems. Relationships resolved once, compounded forever.</div>
        <div class="bento-mock" style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center">
          <div class="mock-card" style="flex:1;min-width:120px">
            <div class="mock-card-title">Entities</div>
            <div class="mock-card-val">12,847</div>
          </div>
          <div class="mock-card" style="flex:1;min-width:120px">
            <div class="mock-card-title">Relationships</div>
            <div class="mock-card-val">45,293</div>
          </div>
          <div class="mock-card" style="flex:1;min-width:120px">
            <div class="mock-card-title">Signals/day</div>
            <div class="mock-card-val">2,341</div>
          </div>
        </div>
      </div>
      
      <!-- 3. Memory Loop -->
      <div class="bento-item">
        <div class="bento-num">03 · Memory</div>
        <div class="bento-title">Memory Loop</div>
        <div class="bento-desc">Three-tier memory: conversational, organizational, personal. Governed by humans, owned by you.</div>
        <div class="bento-mock-gold bento-mock" style="background:rgba(184,148,63,0.1);border:1px solid rgba(184,148,63,0.3)">
          <div class="mock-flow">
            <span style="font-family:'IBM Plex Mono',monospace;font-size:0.55rem;color:var(--forest)">Conv</span>
            <span class="mock-arrow">→</span>
            <span style="font-family:'IBM Plex Mono',monospace;font-size:0.55rem;color:var(--forest)">Org</span>
            <span class="mock-arrow">→</span>
            <span style="font-family:'IBM Plex Mono',monospace;font-size:0.55rem;color:var(--forest)">Personal</span>
          </div>
        </div>
      </div>

      <!-- 4. Multi-AI Orchestration - Span 2 -->
      <div class="bento-item span-2">
        <div class="bento-num">04 · Orchestration</div>
        <div class="bento-title">Multi-AI Orchestration</div>
        <div class="bento-desc">Authorize Claude, ChatGPT, Gemini, or any MCP-compatible AI. One fabric. Unlimited AI consumers. Zero lock-in.</div>
        <div class="bento-mock mock-dark" style="background:var(--slate)">
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
            <div class="mock-node" style="background:rgba(244,240,232,0.15)"><span class="dot"></span>Claude</div>
            <div class="mock-node" style="background:rgba(244,240,232,0.15)"><span class="dot"></span>ChatGPT</div>
            <div class="mock-node" style="background:rgba(244,240,232,0.15)"><span class="dot"></span>Gemini</div>
            <div class="mock-node" style="background:rgba(244,240,232,0.15)"><span class="dot"></span>Perplexity</div>
            <div class="mock-node" style="background:rgba(244,240,232,0.15)"><span class="dot"></span>Local LLM</div>
          </div>
          <div style="margin-top:0.75rem;text-align:center">
            <span style="font-family:'IBM Plex Mono',monospace;font-size:0.5rem;color:rgba(244,240,232,0.5);letter-spacing:0.1em">ALL → CAPABILITY FABRIC</span>
          </div>
        </div>
      </div>
      
      <!-- 5. Governance -->
      <div class="bento-item">
        <div class="bento-num">05 · Governance</div>
        <div class="bento-title">Enterprise Governance</div>
        <div class="bento-desc">AI proposes. Humans approve. Organization owns. Complete audit trails.</div>
        <div class="bento-mock">
          <div class="mock-flow" style="flex-direction:column;align-items:flex-start;gap:0.4rem">
            <span style="font-family:'IBM Plex Mono',monospace;font-size:0.55rem;color:rgba(244,240,232,0.8)">Draft → Pending</span>
            <span style="font-family:'IBM Plex Mono',monospace;font-size:0.55rem;color:rgba(244,240,232,0.8)">Pending → <span style="color:var(--gold)">Approved</span></span>
            <span style="font-family:'IBM Plex Mono',monospace;font-size:0.55rem;color:rgba(244,240,232,0.8)">Approved → Published</span>
          </div>
        </div>
      </div>
      
      <!-- 6. Developer Experience - Tall -->
      <div class="bento-item tall">
        <div class="bento-num">06 · DevEx</div>
        <div class="bento-title">Developer Experience</div>
        <div class="bento-desc">TypeScript-first. Edge-native. 30+ connectors. Deploy in minutes.</div>
        <div class="bento-mock" style="font-family:'IBM Plex Mono',monospace;font-size:0.6rem">
          <div style="color:rgba(244,240,232,0.5);margin-bottom:0.5rem">// Connect a system</div>
          <div style="color:var(--paper)">npx iw connector add</div>
          <div style="color:var(--gold);margin-left:1rem">→ hubspot</div>
          <div style="color:rgba(244,240,232,0.5);margin-top:0.75rem;margin-bottom:0.5rem">// Deploy</div>
          <div style="color:var(--paper)">npx iw deploy</div>
          <div style="color:var(--gold);margin-left:1rem">✓ Live in 47s</div>
        </div>
      </div>
    </div>
  </div>
</section>

/* VISUAL PANEL */
.visual-panel{background:var(--paper);border:1px solid var(--rule);border-radius:1rem;padding:1.25rem;box-shadow:0 4px 20px rgba(0,0,0,0.05)}
.visual-panel.dark{background:var(--forest);border-color:var(--forest-mid)}

/* CTA SECTION */
.cta-section{padding:5rem 0;background:var(--forest);color:var(--paper);text-align:center}
.cta-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(1.8rem,4vw,2.8rem);margin-bottom:1rem}
.cta-desc{font-size:1rem;opacity:0.75;max-width:32rem;margin:0 auto 2rem;line-height:1.7}
.cta-buttons{display:flex;flex-wrap:wrap;gap:1rem;justify-content:center}

/* FOOTER */
.footer{border-top:1px solid var(--rule);padding:3rem 2rem 2rem;background:var(--paper-warm)}
.footer-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2rem;max-width:72rem;margin:0 auto}
@media(min-width:768px){.footer-grid{grid-template-columns:repeat(4,1fr)}}
.footer-col h4{font-family:'IBM Plex Mono',monospace;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--forest);margin-bottom:1rem}
.footer-col a{display:block;font-size:0.8rem;color:var(--slate);margin-bottom:0.5rem}
.footer-col a:hover{color:var(--forest)}
.footer-bottom{max-width:72rem;margin:2rem auto 0;padding-top:1.5rem;border-top:1px solid var(--rule);display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:1rem}
.footer-bottom p{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:var(--slate);opacity:0.6;letter-spacing:0.08em}

/* EQUATION DISPLAY */
.equation{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:1rem;padding:2rem;background:var(--paper);border:1px solid var(--rule);border-radius:1rem;margin:1.5rem 0}
.equation-term{font-family:'Bebas Neue',sans-serif;font-size:clamp(1.5rem,4vw,2.5rem);color:var(--forest)}
.equation-term.highlight{color:var(--gold)}
.equation-operator{font-family:'Bebas Neue',sans-serif;font-size:clamp(1.5rem,4vw,2.5rem);color:var(--rule)}
.equation-result{font-family:'Bebas Neue',sans-serif;font-size:clamp(1.5rem,4vw,2.5rem);color:var(--gold);padding:0.5rem 1rem;background:var(--gold-pale);border-radius:0.5rem}
.equation-vs{font-family:'IBM Plex Mono',monospace;font-size:0.7rem;color:var(--slate);text-transform:uppercase;letter-spacing:0.1em}
.equation-bad{text-decoration:line-through;color:var(--red);opacity:0.6}
  </style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
