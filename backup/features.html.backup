      <!-- Card 8: Developer Experience -->
      <div class="bento-card">
        <div class="bento-num">06 · DX</div>
        <div class="bento-title">TYPESCRIPT-FIRST</div>
        <div class="bento-desc">30+ connector adapters. Edge-native on Cloudflare. Type-safe contracts.</div>
        <div class="ui-mock">
