{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.integratewise.co/sprint-doc/v1",
  "title": "Sprint Document Schema",
  "description": "Schema for IntegrateWise sprint documentation front matter",
  "type": "object",
  "required": [
    "sprint_id",
    "title",
    "date_range_start",
    "date_range_end",
    "status",
    "owner",
    "objectives",
    "acceptance_criteria"
  ],
  "properties": {
    "sprint_id": {
      "type": "string",
      "pattern": "^sprint-[0-9]{4}-[0-9]{2}(-[a-z0-9]+)?$",
      "description": "Unique sprint identifier (e.g., sprint-2025-01, sprint-2025-01-hardening)"
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 100,
      "description": "Human-readable sprint title"
    },
    "date_range_start": {
      "type": "string",
      "format": "date",
      "description": "Sprint start date (YYYY-MM-DD)"
    },
    "date_range_end": {
      "type": "string",
      "format": "date",
      "description": "Sprint end date (YYYY-MM-DD)"
    },
    "status": {
      "type": "string",
      "enum": ["planning", "active", "review", "completed", "cancelled"],
      "description": "Current sprint status"
    },
    "owner": {
      "type": "string",
      "minLength": 1,
      "description": "Sprint owner (username or team)"
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^OBJ-[0-9]+$"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "blocked", "cancelled"]
          },
          "assignee": {
            "type": "string"
          }
        }
      },
      "description": "Sprint objectives"
    },
    "scope_lock": {
      "type": "boolean",
      "default": false,
      "description": "Whether sprint scope is locked (no new objectives)"
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "criterion"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-[0-9]+$"
          },
          "criterion": {
            "type": "string",
            "minLength": 10
          },
          "status": {
            "type": "string",
            "enum": ["pending", "passed", "failed", "blocked"]
          },
          "verified_by": {
            "type": "string"
          },
          "verified_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "description": "Sprint acceptance criteria"
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "author", "summary"],
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "author": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          }
        }
      },
      "description": "Change log entries"
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "url"],
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "type": {
            "type": "string",
            "enum": ["doc", "pr", "issue", "external", "design", "spec"]
          }
        }
      },
      "description": "Related links"
    },
    "edit_lock": {
      "type": "boolean",
      "default": false,
      "description": "Whether file is locked for editing"
    },
    "locked_by": {
      "type": "string",
      "description": "Username of lock holder"
    },
    "locked_until": {
      "type": "string",
      "format": "date-time",
      "description": "Lock expiration timestamp"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Sprint tags for categorization"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^sprint-[0-9]{4}-[0-9]{2}(-[a-z0-9]+)?$"
      },
      "description": "Dependent sprint IDs"
    }
  },
  "additionalProperties": false
}
