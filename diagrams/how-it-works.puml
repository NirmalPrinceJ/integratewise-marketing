@startuml IntegrateWise OS - How It Works

!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Inter
skinparam defaultFontSize 12
skinparam ArrowColor #4F46E5
skinparam BoxBorderColor #E5E7EB
skinparam SequenceGroupBorderColor #6366F1
skinparam SequenceGroupBackgroundColor #F5F3FF

title IntegrateWise OS - End-to-End Sequence Flow

actor "Source\n(Slack)" as Source
participant "Hub\n(Gateway)" as Hub
participant "AI Loader\n(Transform)" as Loader
database "Spine\n(Storage)" as Spine
participant "Brain\n(Memory)" as Brain
participant "Agents\n(Automation)" as Agents
participant "Render\n(Output)" as Render
actor "Destination\n(Notion/Gmail)" as Dest

== Webhook Ingestion ==

Source -> Hub: POST /webhooks/v1/{workspace}/{source}\n**Headers:** X-IW-Signature, X-IW-Timestamp, X-IW-Idempotency-Key
activate Hub

Hub -> Hub: Verify HMAC-SHA256 signature
Hub -> Hub: Check timestamp tolerance (5min)
Hub -> Hub: Validate idempotency key

alt Signature Invalid
    Hub --> Source: 401 invalid_signature
else Timestamp Out of Range
    Hub --> Source: 401 invalid_timestamp
else Duplicate Event
    Hub --> Source: 200 {"status": "duplicate"}
end

Hub -> Hub: Evaluate RBAC policy
Hub -> Hub: Check workspace mode (Full/Render Only)

Hub --> Source: 200 {"status": "accepted"}

== Data Transformation ==

Hub -> Loader: Route to Loader
activate Loader

Loader -> Loader: Extract source fields
Loader -> Loader: Apply mapping transforms
Loader -> Loader: Validate against schema

alt Validation Failed
    Loader -> Hub: Log validation error
    Loader --> Hub: Skip record, continue batch
end

Loader -> Spine: Write SpineEntity
activate Spine

Spine -> Spine: Deduplicate by external_ref
Spine -> Spine: Resolve conflicts (strategy)
Spine -> Spine: Store entity
Spine -> Spine: Update relationships

Spine --> Loader: Entity stored (entity_id)
deactivate Spine

Loader --> Hub: Sync complete
deactivate Loader

== Memory Update ==

Spine -> Brain: Notify: new entity
activate Brain

Brain -> Brain: Ingest to memory
Brain -> Brain: Compute embeddings
Brain -> Brain: Auto-link related entities
Brain -> Brain: Detect patterns/triggers

Brain --> Spine: Links discovered
deactivate Brain

== Agent Execution ==

Brain -> Agents: Trigger: pattern detected
activate Agents

Agents -> Brain: Retrieve context
Brain --> Agents: Memories + related entities

Agents -> Agents: Plan actions
Agents -> Agents: Check approval requirements

alt Approval Required
    Agents -> Hub: Create approval request
    Hub -> Agents: Approval granted/denied
end

alt Approval Granted
    Agents -> Render: Execute template
    activate Render
    
    Render -> Render: Load template
    Render -> Render: Bind parameters
    Render -> Render: Generate output
    
    Render -> Dest: Export (Notion page / Gmail draft)
    Dest --> Render: Created (external_id, url)
    
    Render --> Agents: Render complete
    deactivate Render
    
    Agents -> Spine: Update linked entities
else Approval Denied
    Agents -> Hub: Log denial
end

Agents --> Hub: Execution complete
deactivate Agents

== Audit Logging ==

Hub -> Hub: Create audit record
note right of Hub
  {
    "workspace_id": "ws_123",
    "actor_id": "agent_001",
    "action_type": "template.execute",
    "resource_type": "notion.page",
    "outcome": "success",
    "timestamp": "2025-01-15T10:30:15Z"
  }
end note

deactivate Hub

@enduml
