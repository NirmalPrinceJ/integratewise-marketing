@startuml IntegrateWise OS - Component Architecture

!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Inter
skinparam componentStyle rectangle

title IntegrateWise OS - Component Architecture

package "External Tools" {
    [Notion] as notion
    [Slack] as slack
    [Gmail] as gmail
    [HubSpot] as hubspot
    [Stripe] as stripe
    [Calendar] as calendar
    [AI Tools] as ai
}

package "IntegrateWise OS" {
    
    package "Hub (Gateway Layer)" {
        [Auth Adapters] as auth
        [Policy Engine] as policy
        [Routing Rules] as routing
        [Audit Sinks] as audit
        [Usage Meter] as meter
    }
    
    package "AI Loader" {
        [Source Connectors] as connectors
        [Transform Engine] as transform
        [Validation] as validation
        [Conflict Resolver] as conflict
    }
    
    package "Spine (Data Layer)" {
        database "Entities" as entities {
            [Task]
            [Note]
            [Conversation]
            [Plan]
            [HealthMetric]
        }
        [Relationships] as relationships
        [Indexes] as indexes
    }
    
    package "Brain (Memory)" {
        [Short-term Memory] as stm
        [Long-term Memory] as ltm
        [Entity Linker] as linker
        [Embeddings] as embeddings
    }
    
    package "Agents" {
        [Trigger Handler] as triggers
        [Planner] as planner
        [Approval Flow] as approval
        [Sandbox Executor] as sandbox
    }
    
    package "Render" {
        [Template Engine] as templates
        [Output Generators] as generators
        [Export Connectors] as exporters
    }
}

package "Outputs" {
    [Notion Pages] as notion_out
    [Gmail Drafts] as gmail_out
    [Dashboards] as dashboards
    [Reports] as reports
}

' External to Hub
notion --> auth
slack --> auth
gmail --> auth
hubspot --> auth
stripe --> auth
calendar --> auth
ai --> auth

' Hub flow
auth --> policy
policy --> routing
routing --> audit
routing --> meter

' Hub to Loader
routing --> connectors

' Loader flow
connectors --> transform
transform --> validation
validation --> conflict

' Loader to Spine
conflict --> entities

' Spine internals
entities --> relationships
entities --> indexes

' Spine to Brain
entities --> stm
entities --> ltm
relationships --> linker
indexes --> embeddings

' Brain to Agents
embeddings --> triggers
linker --> triggers
triggers --> planner
planner --> approval
approval --> sandbox

' Agents to Render
sandbox --> templates
templates --> generators
generators --> exporters

' Render to Outputs
exporters --> notion_out
exporters --> gmail_out
exporters --> dashboards
exporters --> reports

' Audit capture
sandbox --> audit

@enduml
