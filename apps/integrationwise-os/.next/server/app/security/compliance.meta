{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/security/layout,_N_T_/security/compliance/layout,_N_T_/security/compliance/page,_N_T_/security/compliance"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/security/compliance/__PAGE__",
    "/security/compliance",
    "/security",
    "/_index",
    "/_head"
  ]
}