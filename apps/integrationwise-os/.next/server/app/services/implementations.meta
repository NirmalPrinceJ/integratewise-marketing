{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/services/layout,_N_T_/services/implementations/layout,_N_T_/services/implementations/page,_N_T_/services/implementations"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/services/implementations/__PAGE__",
    "/services/implementations",
    "/services",
    "/_index",
    "/_head"
  ]
}