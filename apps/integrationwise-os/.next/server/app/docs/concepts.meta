{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/concepts/layout,_N_T_/docs/concepts/page,_N_T_/docs/concepts"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/concepts/__PAGE__",
    "/docs/concepts",
    "/docs",
    "/_index",
    "/_head"
  ]
}