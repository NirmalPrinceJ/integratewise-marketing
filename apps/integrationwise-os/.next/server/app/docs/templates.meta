{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/templates/layout,_N_T_/docs/templates/page,_N_T_/docs/templates"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/templates/__PAGE__",
    "/docs/templates",
    "/docs",
    "/_index",
    "/_head"
  ]
}